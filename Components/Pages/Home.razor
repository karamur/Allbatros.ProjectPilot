@page "/"

<PageTitle>Allbatros Operations Hub</PageTitle>

<div class="container py-4">
    <div class="p-4 p-md-5 mb-4 bg-light rounded-3 border">
        <div class="container-fluid py-3">
            <h1 class="display-6 fw-bold">Allbatros Operations Hub</h1>
            <p class="col-md-10 fs-5">
                ClickUp benzeri proje yonetimi, AI destekli ozetler ve operasyon gorunurlugu icin gelistirilen merkezi calisma alani.
            </p>
            <p class="mb-0 text-muted">
                Bu surum; entegrasyon ayarlari, gorev panosu, AI insight akisi ve ileride eklenecek otomasyon modulleri icin temel altyapiyi sunar.
            </p>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Entegrasyon Merkezi</h5>
                    <p class="card-text">ClickUp ayarlari, baglanti testi ve canli task cekme akisi tek merkezden yonetilebilir.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">AI Copilot</h5>
                    <p class="card-text">Gorev ozeti, risk sinyali, sonraki aksiyon ve onceliklendirme onerileri uretilir.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Operasyon Panosu</h5>
                    <p class="card-text">Kanban akisi, teslim tarihi riski ve ekip sorumluluklari tek ekranda takip edilir.</p>
                </div>
            </div>
        </div>
    </div>
</div>
